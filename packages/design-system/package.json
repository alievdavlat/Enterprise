{
  "name": "@enterprise/design-system",
  "version": "1.0.0",
  "description": "Enterprise Design System - UI Components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./table": {
      "types": "./dist/table.d.ts",
      "import": "./dist/table.mjs",
      "require": "./dist/table.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.mjs",
      "require": "./dist/editor.js"
    },
    "./styles": "./dist/styles.css"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsup --config tsup.config.ts && tsc --emitDeclarationOnly",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": ">=0.300.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@tanstack/react-table": ">=8.0.0",
    "@tiptap/extension-placeholder": ">=2.0.0",
    "@tiptap/react": ">=2.0.0",
    "@tiptap/starter-kit": ">=2.0.0",
    "lucide-react": ">=0.300.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "cross-env": "^7.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "^8.0.0"
  }
}
