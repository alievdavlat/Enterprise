PORT=9390
HOST=0.0.0.0
APP_NAME=Enterprise CMS
APP_URL=http://localhost:9390
NODE_ENV=development

# JWT
JWT_SECRET=enterprise-super-secret-jwt-key-change-in-production
ADMIN_JWT_SECRET=enterprise-admin-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (choose one)
DB_CLIENT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enterprise
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# For MongoDB:
# DB_CLIENT=mongodb
# DB_URI=mongodb://localhost:27017/enterprise

# For MySQL:
# DB_CLIENT=mysql
# DB_HOST=localhost
# DB_PORT=3306

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100

# GraphQL
GRAPHQL_ENABLED=true

# File uploads
UPLOAD_DIR=./public/uploads
