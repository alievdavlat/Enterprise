{
  "name": "create-enterprise-app",
  "version": "1.0.0",
  "description": "CLI tool to generate a new Enterprise CMS project",
  "main": "dist/index.js",
  "bin": {
    "create-enterprise-app": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepare:templates": "node scripts/prepare-default-template.js",
    "prepublishOnly": "npm run build && npm run prepare:templates"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^20.11.0",
    "@types/inquirer": "^8.2.10",
    "@types/fs-extra": "^11.0.4"
  }
}
