# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated declaration/source maps for root configs (eslint, postcss, next, tailwind)
eslint.config.d.mts
eslint.config.d.mts.map
postcss.config.d.mts
postcss.config.d.mts.map
next.config.d.ts
next.config.d.ts.map
next.config.js.map
tailwind.config.d.ts
tailwind.config.d.ts.map
tailwind.config.js.map
